# Shared password to access the web interface
IRCBOT_PASSWORD=changeme

# Separate admin password (grants access to IP tracking / download logs)
IRCBOT_ADMIN_PASSWORD=admin

# Secret key for JWT token signing (generate a random string)
IRCBOT_JWT_SECRET=change-this-to-a-random-secret

# IRC settings
IRCBOT_IRC_SERVER=irc.irchighway.net
IRCBOT_IRC_PORT=6697
# IRCBOT_IRC_NICK=        # Leave blank to auto-generate a random human-looking nick each connection
IRCBOT_IRC_CHANNEL=#ebooks

# Storage paths (defaults are fine for local dev)
# IRCBOT_STORAGE_PATH=./backend/storage
# IRCBOT_DB_PATH=./data/ircbot.db
